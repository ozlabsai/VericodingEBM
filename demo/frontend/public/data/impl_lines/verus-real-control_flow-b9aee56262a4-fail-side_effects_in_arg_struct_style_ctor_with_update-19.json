{"impl": {"impl_id": "verus-real-control_flow-b9aee56262a4-fail-side_effects_in_arg_struct_style_ctor_with_update-19", "spec_id": "verus-real-control_flow-b9aee56262a4", "status": "fail", "whole_impl_energy": -6.059600353240967, "spec_text": "\n        struct Foo { b: u64, a: u64, c: u64 }\n", "impl_text": "        fn test_fails() {\n            let foo0 = Foo { a: 0, b: 0, c: 19 };\n\n            let mut x = 24;\n            let mut y = 30;\n\n            let z = Foo { a: x, b: ({ x = 60; y }), ..foo0 };\n\n            assert(z == Foo { a: 60, b: 30, c: 19 }); // FAILS\n        }\n\n        fn test_ok() {\n            let foo0 = Foo { a: 0, b: 0, c: 19 };\n\n            let mut x = 24;\n            let mut y = 30;\n\n            let z = Foo { a: x, b: ({ x = 60; y }), ..foo0 };\n\n            assert(z == Foo { a: 24, b: 30, c: 19 });\n            assert(x == 60);\n        }\n\n        fn test2_fails() {\n            let foo0 = Foo { a: 0, b: 0, c: 19 };\n\n            let mut x = 24;\n            let mut y = 30;\n\n            let z = Foo { a: ({ x = 60; y }), b: x, ..foo0 };\n\n            assert(z == Foo { a: 30, b: 24, c: 19 }); // FAILS\n        }\n\n        fn test2_ok() {\n            let foo0 = Foo { a: 0, b: 0, c: 19 };\n\n            let mut x = 24;\n            let mut y = 30;\n\n            let z = Foo { a: ({ x = 60; y }), b: x, ..foo0 };\n\n            assert(z == Foo { a: 30, b: 60, c: 19 });\n            assert(x == 60);\n        }\n\n        fn test3_fails() {\n            let mut foo0 = Foo { a: 0, b: 0, c: 19 };\n\n            let mut x = 24;\n            let mut y = 30;\n\n            let z = Foo { a: x, b: y, ..({ x = 20; foo0 }) };\n\n            assert(z == Foo { a: 20, b: 30, c: 19 }); // FAILS\n        }\n\n        fn test3_ok() {\n            let mut foo0 = Foo { a: 0, b: 0, c: 19 };\n\n            let mut x = 24;\n            let mut y = 30;\n\n            let z = Foo { a: x, b: y, ..({ x = 20; foo0 }) };\n\n            assert(z == Foo { a: 24, b: 30, c: 19 });\n            assert(x == 20);\n        }\n\n        fn test4_fails() {\n            let mut foo0 = Foo { a: 0, b: 0, c: 19 };\n\n            let mut x = 24;\n            let mut y = 30;\n\n            let z = Foo { a: x, b: ({ foo0 = Foo { a: 13, b: 14, c: 199 }; 20  }), ..foo0 };\n\n            assert(z == Foo { a: 24, b: 20, c: 19 }); // FAILS\n        }\n\n        fn test4_ok() {\n            let mut foo0 = Foo { a: 0, b: 0, c: 19 };\n\n            let mut x = 24;\n            let mut y = 30;\n\n            let z = Foo { a: x, b: ({ foo0 = Foo { a: 13, b: 14, c: 199 }; 20  }), ..foo0 };\n\n            assert(z == Foo { a: 24, b: 20, c: 199 });\n            assert(foo0 == Foo { a: 13, b: 14, c: 199 });\n        }\n    "}, "lines": [{"line_idx": 0, "line_text": "        fn test_fails() {", "energy": -3.699617385864258, "is_buggy": false, "x": -9.027544021606445, "y": -3.358438014984131}, {"line_idx": 1, "line_text": "            let foo0 = Foo { a: 0, b: 0, c: 19 };", "energy": -3.9542057514190674, "is_buggy": false, "x": 4.543094635009766, "y": 0.166124165058136}, {"line_idx": 2, "line_text": "            let mut x = 24;", "energy": -5.067037105560303, "is_buggy": false, "x": 3.0831074714660645, "y": -1.2894246578216553}, {"line_idx": 3, "line_text": "            let mut y = 30;", "energy": -4.6255269050598145, "is_buggy": false, "x": 2.9150662422180176, "y": -1.1534595489501953}, {"line_idx": 4, "line_text": "            let z = Foo { a: x, b: ({ x = 60; y }), ..foo0 };", "energy": -4.310191631317139, "is_buggy": false, "x": 2.8305022716522217, "y": -0.8790476322174072}, {"line_idx": 5, "line_text": "            assert(z == Foo { a: 60, b: 30, c: 19 }); // FAILS", "energy": -4.739355564117432, "is_buggy": true, "x": 9.181588172912598, "y": -2.815753698348999}, {"line_idx": 6, "line_text": "        }", "energy": -4.7995219230651855, "is_buggy": false, "x": -0.004368782043457031, "y": 11.628710746765137}, {"line_idx": 7, "line_text": "       