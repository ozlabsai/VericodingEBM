{"impl": {"impl_id": "verus-real-hash-2027b66e022e-pass-test_hash_set_struct-1", "spec_id": "verus-real-hash-2027b66e022e", "status": "pass", "whole_impl_energy": -22.54955291748047, "spec_text": "\n        use core::hash::{Hash, Hasher};\n        use std::collections::HashSet;\n        use vstd::prelude::*;\n\n        #[derive(PartialEq, Eq)]\n        struct MyStruct\n        {\n            pub i: u16,\n            pub j: i32,\n        }\n\n        impl Hash for MyStruct\n        {\n            #[verifier::external_body]\n            fn hash<H>(&self, state: &mut H)\n                where\n                    H: Hasher\n            {\n                self.i.hash(state);\n                self.j.hash(state);\n            }\n        }\n\n        fn test()\n        {\n            assume(vstd::std_specs::hash::obeys_key_model::<MyStruct>());\n\n            let mut m = HashSet::<MyStruct>::new();\n            assert(m@ == Set::<MyStruct>::empty());\n            let s1 = MyStruct{ i: 3, j: 7 };\n            let res = m.insert(s1);\n            assert(res);\n            let res = m.insert(MyStruct{ i: 3, j: 7 });\n            assert(!res);\n\n            let s2 = MyStruct{ i: 3, j: 7 };\n            assert(m@.contains(s2));\n\n            let b = m.contains(&s2);\n            assert(b);\n\n            let v = m.get(&s2);\n            match v {\n                Some(v) => assert(*v == s2),\n                None => assert(false),\n            }\n\n            let s3 = MyStruct { i: 9, j: 9 };\n\n            m.insert(MyStruct { i: 9, j: 9 });\n            let res = m.remove(&s3);\n            assert(res);\n            let res = m.remove(&s3);\n            assert(!res);\n\n            m.clear();\n            assert(!m@.contains(s2));\n            let b = m.contains(&s2);\n            assert(!b);\n        }\n    ", "impl_text": "\n        use core::hash::{Hash, Hasher};\n        use std::collections::HashSet;\n        use vstd::prelude::*;\n\n        #[derive(PartialEq, Eq)]\n 