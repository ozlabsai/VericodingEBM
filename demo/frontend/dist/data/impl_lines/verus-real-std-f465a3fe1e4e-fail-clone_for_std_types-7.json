{"impl": {"impl_id": "verus-real-std-f465a3fe1e4e-fail-clone_for_std_types-7", "spec_id": "verus-real-std-f465a3fe1e4e", "status": "fail", "whole_impl_energy": -5.3655290603637695, "spec_text": "\n        use vstd::*;\n        use vstd::prelude::*;\n", "impl_text": "        fn test_bool(v: bool) {\n            let w = v.clone();\n            assert(w == v);\n        }\n\n        fn test_bool_vec(v: Vec<bool>) {\n            let w = v.clone();\n            assert(w@ =~= v@);\n        }\n\n        fn test_char(v: char) {\n            let w = v.clone();\n            assert(w == v);\n        }\n\n        fn test_char_vec(v: Vec<char>) {\n            let w = v.clone();\n            assert(w@ =~= v@);\n        }\n\n        struct Y { }\n\n        fn test_vec_ref(v: Vec<&Y>) {\n            let w = v.clone();\n            assert(w@ =~= v@);\n        }\n\n        struct X { i: u64 }\n\n        impl Clone for X {\n            fn clone(&self) -> Self { X { i: 0 } }\n        }\n\n        fn test_vec_fail(v: Vec<X>)\n            requires v.len() >= 1,\n        {\n            let w = v.clone();\n            assert(v[0] == w[0]); // FAILS\n        }\n\n        fn test_vec_deep_view() {\n            let mut v1: Vec<u8> = Vec::new();\n            v1.push(3);\n            v1.push(4);\n            let c1 = v1.clone();\n            let ghost g1 = c1@ == v1@;\n            assert(g1);\n            let mut v2: Vec<Vec<u8>> = Vec::new();\n            v2.push(v1.clone());\n            v2.push(v1.clone());\n            let c2 = v2.clone();\n            let ghost g2 = c2.deep_view() == v2.deep_view();\n            assert(g2);\n            assert(c2@ == v2@); // FAILS\n        }\n\n        fn test_vec_deep_view_char() {\n            let mut v1: Vec<char> = Vec::new();\n            v1.push('a');\n            v1.push('b');\n            let c1 = v1.clone();\n            let ghost g1 = c1@ == v1@;\n            assert(g1);\n            let mut v2: Vec<Vec<char>> = Vec::new();\n            v2.push(v1.clone());\n            v2.push(v1.clone());\n            let c2 = v2.clone();\n            let ghost g2 = c2.deep_view() == v2.deep_view();\n            assert(g2);\n            assert(c2@ == v2@); // FAILS\n        }\n\n        fn test_slice_deep_view(a1: &[Vec<u8>], a2: &[Vec<u8>])\n            requires\n                a1.len() == 1,\n                a2.len() == 1,\n                a1[0].len() == 1,\n                a2[0].len() == 1,\n                a1[0][0] == 10,\n                a2[0][0] == 10,\n            ensures\n                a1.deep_view() == a2.deep_view(),\n        {\n            assert(a1.deep_view() =~~= a2.deep_view()); // TODO: get rid of this?\n        }\n\n        fn test_array_deep_view(a1: &[Vec<u8>; 1], a2: &[Vec<u8>; 1])\n            requires\n                a1[0].len() == 1,\n                a2[0].len() == 1,\n                a1[0][0] == 10,\n                a2[0][0] == 10,\n            ensures\n                a1.deep_view() == a2.deep_view(),\n        {\n            assert(a1.deep_view() =~~= a2.deep_view()); // TODO: get rid of this?\n        }\n    "}, "lines": [{"line_idx": 0, "line_text": "        fn test_bool(v: bool) {", "energy": -4.184098720550537, "is_buggy": false, "x": -9.151901245117188, "y": -3.233307361602783}, {"line_idx": 1, "line_text": "            let w = v.clone();", "energy": -4.928062915802002, "is_buggy": false, "x": 3.108733892440796, "y": -1.3897589445114136}, {"line_idx": 2, "line_text": "            assert(w == v);", "energy": -3.629164934158325, "is_buggy": false, "x": 5.350625038146973, "y": 2.3097329139709473}, {"line_idx": 3, "line_text": "        }", "energy": -4.356503963470459, "is_buggy": false, "x": -0.44481968879699707, "y": 11.219535827636719}, {"line_idx": 4, "line_text": "        fn test_bool_vec(v: Vec<bool>) {", "energy": -5.1274590492248535, "is_buggy": false, "x": -5.650786876678467, "y": 2.739201784133911}, {"line_idx": 5, "line_text": "            let w = v.clone();", "energy": -4.46274995