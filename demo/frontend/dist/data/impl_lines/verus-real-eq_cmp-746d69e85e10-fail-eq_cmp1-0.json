{"impl": {"impl_id": "verus-real-eq_cmp-746d69e85e10-fail-eq_cmp1-0", "spec_id": "verus-real-eq_cmp-746d69e85e10", "status": "fail", "whole_impl_energy": -6.851500988006592, "spec_text": "\n        use vstd::laws_eq::*;\n        use vstd::laws_cmp::*;\n        use vstd::std_specs::cmp::{OrdSpec, PartialEqSpec, PartialOrdSpec};\n        use core::cmp::Ordering;\n\n        fn test_eq<T: Ord>(x: &T, y: &T) -> (r: bool)\n            requires\n                obeys_cmp::<T>(),\n            ensures\n                r <==> x.eq_spec(y),\n        {\n            reveal(obeys_cmp_partial_ord);\n            reveal(obeys_cmp_ord);\n\n            if x.lt(y) {\n                return false;\n            }\n            if x.gt(y) {\n                return false;\n            }\n            true\n        }\n\n        fn test_eq_wrong<T: Ord>(x: &T, y: &T) -> (r: bool)\n            requires\n                obeys_cmp::<T>(),\n            ensures\n                r <==> x.eq_spec(y),\n        {\n            reveal(obeys_cmp_partial_ord);\n            reveal(obeys_cmp_ord);\n\n            if x.lt(y) {\n                return false;\n            }\n            if x.gt(y) {\n                return true; // FAILS\n            }\n            true\n        }\n", "impl_text": "        fn test() {\n            let b = test_eq(&Some(5u8), &Some(4u8 + 1));\n            assert(b);\n\n            let b = test_eq(&Some(5u8), &Some(4u8 - 1));\n            assert(!b);\n        }\n\n        struct P(u8, bool);\n\n        impl PartialEq for P {\n            fn eq(&self, other: &P) -> (b: bool)\n                ensures\n                    b <==> self == other\n            {\n                self.0 == other.0 && self.1 == other.1\n            }\n        }\n        impl vstd::std_specs::cmp::PartialEqSpecImpl for P {\n            closed spec fn obeys_eq_spec() -> bool {\n                true\n            }\n\n            closed spec fn eq_spec(&self, other: &P) -> bool {\n                self == other\n            }\n        }\n        impl Eq for P {\n        }\n\n        broadcast proof fn lemma_s_obeys_eq_spec()\n            ensures\n                #[trigger] obeys_eq::<P>(),\n        {\n            reveal(obeys_eq_spec_properties);\n        }\n\n        broadcast proof fn lemma_s_obeys_concrete_eq()\n            ensures\n                #[trigger] obeys_concrete_eq::<P>(),\n        {\n            reveal(obeys_concrete_eq);\n        }\n\n        fn test_p_eq() {\n            let b = P(3, true).eq(&P(3, false));\n            assert(!b);\n        }\n\n        fn test_p_ee() {\n            let b = P(3, true) == P(3, false);\n            assert(!b);\n        }\n\n        #[derive(PartialEq, Eq, StructuralEq)]\n        struct S(u8, bool);\n\n        fn check_eq<T: Eq>(x: &T, y: &T) -> (b: bool)\n            requires\n                obeys_concrete_eq::<T>(),\n            ensures\n                b <==> x == y,\n        {\n            reveal(obeys_concrete_eq);\n            x.eq(y)\n        }\n\n        fn test_s() {\n            let b = check_eq(&S(3, true), &S(3, false));\n            assert(!b);\n            let b = S(3, true) == S(3, false);\n            assert(!b);\n        }\n    "}, "lines": [{"line_idx": 0, "line_text": "        fn test() {", "energy": -3.928925037384033, "is_buggy": false, "x": -6.878218650817871, "y": -2.3887922763824463}, {"line_idx": 1, "line_text": "            let b = test_eq(&Some(5u8), &Some(4u8 + 1));", "energy": -2.573293924331665, "is_buggy": false, "x": 5.318562030792236, "y": 2.0513038635253906}, {"line_idx": 2, "line_text": "            assert(b);", "energy": -2.0552921295166016, "is_buggy": false, "x": 5.387013912200928, "y": 2.294959306716919}, {"line_idx": 3, "line_text": "            let b = test_eq(&Some(5u8), &Some(4u8 - 1));", "energy": -3.530024528503418, "is_buggy": false, "x": 5.24434757232666, "y": 1.9932925701141357}, {"line_idx": 4, "line_text": "            assert(!b);", "energy": -2.2688357830047607, "is_buggy":