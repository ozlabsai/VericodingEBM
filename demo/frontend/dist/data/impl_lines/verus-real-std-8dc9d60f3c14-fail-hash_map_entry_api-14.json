{"impl": {"impl_id": "verus-real-std-8dc9d60f3c14-fail-hash_map_entry_api-14", "spec_id": "verus-real-std-8dc9d60f3c14", "status": "fail", "whole_impl_energy": -14.109670639038086, "spec_text": "\n        use vstd::prelude::*;\n        use vstd::std_specs::hash::*;\n        use std::collections::hash_map::*;\n        use std::hash::*;\n", "impl_text": "        fn test1() {\n            let mut m = HashMap::<u64, u64>::new();\n\n            // Use entry API to insert to the map\n\n            let entry = m.entry(5);\n            assert(entry.key() == 5 && entry.value() == None);\n\n            let value_ref = entry.or_insert(20);\n            assert(*value_ref == 20);\n\n            *value_ref = 40;\n\n            assert(m@.dom().contains(5) && m@[5] == 40);\n\n            // Use entry API to remove from the map\n\n            let entry = m.entry(5);\n            match entry {\n                Entry::Occupied(occupied_entry) => {\n                    let (k, v) = occupied_entry.remove_entry();\n                    assert(k == 5);\n                    assert(v == 40);\n                }\n                Entry::Vacant(_) => {\n                    assert(false);\n                }\n            }\n\n            assert(!m@.dom().contains(5));\n\n            assert(false); // FAILS\n        }\n\n        fn test_occupied_entry() {\n            let mut m = HashMap::<u64, u64>::new();\n            let entry = m.entry(5);\n            let mut occ_entry = entry.insert_entry(20);\n\n            assert(occ_entry.key() == 5);\n            assert(occ_entry.value() == 20);\n\n            let x = occ_entry.get();\n            assert(*x == 20);\n\n            let x = occ_entry.get_mut();\n            assert(*x == 20);\n            *x = 30;\n\n            assert(occ_entry.key() == 5);\n            assert(occ_entry.value() == 30);\n\n            let x = occ_entry.into_mut();\n            assert(*x == 30);\n            *x = 40;\n\n            assert(m@.dom().contains(5));\n            assert(m@[5] == 40);\n\n            // Now let's remove it\n\n            let entry = m.entry(5);\n            let mut occ_entry = entry.insert_entry(60);\n\n            let (removed_key, removed_value) = occ_entry.remove_entry();\n            assert(removed_key == 5);\n            assert(removed_value == 60);\n\n            assert(m@ =~= Map::empty());\n\n            assert(false); // FAILS\n        }\n\n        fn test_occupied_entry2() {\n            let mut m = HashMap::<u64, u64>::new();\n            let entry = m.entry(5);\n            let mut occ_entry = entry.insert_entry(20);\n\n            let old_value = occ_entry.insert(17);\n            assert(old_value == 20);\n\n            assert(m@.dom().contains(5));\n            assert(m@[5] == 17);\n\n            let entry = m.entry(5);\n            let mut occ_entry = entry.insert_entry(20);\n            let mut old_value = occ_entry.remove();\n            assert(old_value == 20);\n\n            assert(m@ =~= Map::empty());\n\n            assert(false); // FAILS\n        }\n\n        fn test_vacant_entry() {\n            let mut m = HashMap::<u64, u64>::new();\n            let entry = m.entry(5);\n\n            let Entry::Vacant(vac_entry) = entry else { assert(false); return; };\n\n            let k = vac_entry.into_key();\n            assert(k == 5);\n\n            assert(m@ =~= Map::empty());\n\n            assert(false); // FAILS\n        }\n\n        fn test_vacant_entry2() {\n            let mut m = HashMap::<u64, u64>::new();\n            let entry = m.entry(5);\n\n            let Entry::Vacant(vac_entry) = entry else { assert(false); return; };\n\n            // do nothing\n\n            assert(m@ =~= Map::empty());\n\n            assert(false); // FAILS\n        }\n\n        fn test_vacant_entry3() {\n            let mut m = HashMap::<u64, u64>::new();\n            let entry = m.entry(5);\n\n            let Entry::Vacant(vac_entry) = entry else { assert(false); return; };\n\n            let r = vac_entry.insert(20);\n            assert(*r == 20);\n            *r = 30;\n\n            assert(m@.dom().contains(5) && m[5] == 30);\n\n            assert(false); // FAILS\n        }\n\n        fn test_vacant_entry4() {\n            let mut m = HashMap::<u64, u64>::new();\n            let entry = m.entry(5);\n\n            let Entry::Vacant(vac_entry) = entry else { assert(false); return; };\n\n            let mut occ_entry = vac_entry.insert_entry(20);\n            let r = occ_entry.get_mut();\n            assert(*r == 20);\n            *r = 30;\n\n            assert(m@.dom().contains(5) && m[5] == 30);\n\n            assert(false); // FAILS\n        }\n    "}, "lines": [{"line_idx": 0, "line_text": "        fn test1() {", "energy": -4.197165489196777, "is_buggy": false, "x": -8.979778289794922, "y": -3.3855018615722656}, {"line_idx": 1, "line_text": "            let mut m = HashMap::<u64, u64>::new();", "energy": -4.446842670440674, "is_buggy": false, "x": 3.2902092933654785, "y": -1.3321985006332397}, {"line_idx": 2, "line_text": "            let entry = m.entry(5);", "energy": -4.435074329376221, "is_buggy": false, "x": 4.237644672393799, "y": -0.5155054330825806}, {"line_idx": 3, "line_text": "            assert(entry.key() == 5 && entry.value() == None);", "energy": -2.799569845199585, "is_buggy": false, "x": 5.29224967956543, "y": 2.8101229667663574}, {"line_idx": 4, "line_text": "            let value_ref = entry.or_insert(20);", "energy": -3.029163122177124, "is_buggy": false, "x": 5.274655342102051, "y": 2.8650381565093994}, {"line_idx": 5, "line_text": "            assert(*value_ref == 20);", "energy": -2.806253433227539, "is_buggy": false, "x": 4.960640907287598, "y": 3.2650392055511475}, {"line_idx": 6, "line_text": "            assert(m@.dom().contains(5) && m@[5] == 40);", "energy": -1.765424132347107, "is_buggy": false, "x": 5.112067699432373, "y": 3.2063169479370117}, {"line_idx": 7, "line_text": "            let entry = m.entry(5);", "energy": -3.5708601474