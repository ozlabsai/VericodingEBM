{"impl": {"impl_id": "verus-real-hash-90dd5db32f1d-pass-test_hash_map_with_view-2", "spec_id": "verus-real-hash-90dd5db32f1d", "status": "pass", "whole_impl_energy": -21.186269760131836, "spec_text": "\n        use core::hash::{Hash, Hasher};\n        use vstd::hash_map::HashMapWithView;\n        use vstd::prelude::*;\n\n        #[derive(PartialEq, Eq)]\n        pub struct MyStruct\n        {\n            pub i: u16,\n            pub j: i32,\n        }\n\n        impl Hash for MyStruct\n        {\n            #[verifier::external_body]\n            fn hash<H>(&self, state: &mut H)\n                where\n                    H: Hasher\n            {\n                self.i.hash(state);\n                self.j.hash(state);\n            }\n        }\n\n        impl View for MyStruct\n        {\n            type V = (MyStruct, int);\n            open spec fn view(&self) -> Self::V\n            {\n                (*self, self.i + self.j)\n            }\n        }\n\n        fn test()\n        {\n            assume(vstd::std_specs::hash::obeys_key_model::<MyStruct>());\n\n            let mut m = HashMapWithView::<MyStruct, u32>::new();\n            assert(m@ == Map::<(MyStruct, int), u32>::empty());\n\n            let b = m.is_empty();\n            assert(b);\n\n            let s1 = MyStruct{ i: 3, j: 7 };\n            m.insert(s1, 4);\n\n            let b = m.is_empty();\n            assert(!b);\n\n            let s2 = MyStruct{ i: 3, j: 7 };\n            let ghost w: (MyStruct, int) = (MyStruct{ i: 3, j: 7 }, 10);\n            assert(s1@ == w);\n            assert(s2@ == w);\n            assert(m@[w] == 4);\n            assert(m@.contains_key(w));\n\n            assert(m@.len() == 1);\n            assert(m.len() == 1) by {\n                vstd::hash_map::axiom_hash_map_with_view_spec_len(&m);\n            }\n            let n = m.len();\n            assert(n == 1);\n\n            let b = m.contains_key(&s2);\n            assert(b);\n\n            let v = m.get(&s2);\n            match v {\n                Some(v) => assert(*v == 4),\n                None => assert(false),\n            }\n\n            m.remove(&s2);\n            assert(!m@.contains_key(w));\n\n            let s3 = MyStruct{ i: 3, j: 7 };\n            m.insert(s3, 8);\n            m.clear();\n            assert(!m@.contains_key(w));\n            let b = m.contains_key(&s2);\n            assert(!b);\n        }\n    ", "impl_text": "\n        use core::hash::{Hash, Hasher};\n        use vstd::hash_map::HashMapWithView;\n        use vstd::prelude::*;\n\n        #[derive(PartialEq, Eq)]\n        pub struct MyStruct\n        {\n            pub i: u16,\n            pub j: i32,\n        }\n\n        impl Hash for MyStruct\n        {\n            #[verifier::external_body]\n            fn hash<H>(&self, state: &mut H)\n                where\n                    H: Hasher\n            {\n                self.i.hash(state);\n                self.j.hash(state);\n            }\n        }\n\n        impl View for MyStruct\n        {\n            type V = (MyStruct, int);\n            open spec fn view(&self) -> Self::V\n            {\n                (*self, self.i + self.j)\n            }\n        }\n\n        fn test()\n        {\n            assume(vstd::std_specs::hash::obeys_key_model::<MyStruct>());\n\n            let mut m = HashMapWithView::<MyStruct, u32>::new();\n            assert(m@ == Map::<(MyStruct, int), u32>::empty());\n\n            let b = m.is_empty();\n            assert(b);\n\n            let s1 = MyStruct{ i: 3, j: 7 };\n            m.insert(s1, 4);\n\n            let b = m.is_empty();\n            assert(!b);\n\n            let s2 = MyStruct{ i: 3, j: 7 };\n            let ghost w: (MyStruct, int) = (MyStruct{ i: 3, j: 7 }, 10);\n            assert(s1@ == w);\n            assert(s2@ == w);\n            assert(m@[w] == 4);\n            assert(m@.contains_key(w));\n\n            assert(m@.len() == 1);\n            assert(m.len() == 1) by {\n                vstd::hash_map::axiom_hash_map_with_view_spec_len(&m);\n            }\n            let n = m.len();\n            assert(n == 1);\n\n            let b = m.contains_key(&s2);\n            assert(b);\n\n            let v = m.get(&s2);\n            match v {\n                Some(v) => assert(*v == 4),\n                None => assert(false),\n            }\n\n            m.remove(&s2);\n            assert(!m@.contains_key(w));\n\n            let s3 = MyStruct{ i: 3, j: 7 };\n            m.insert(s3, 8);\n            m.clear();\n            assert(!m@.contains_key(w));\n            let b = m.contains_key(&s2);\n            assert(!b);\n        }\n    "}, "lines": [{"line_idx": 0, "line_text": "        use core::hash::{Hash, Hasher};", "energy": -3.669715166091919, "is_buggy": false, "x": 2.3034863471984863, "y": -5.801297664642334}, {"line_idx": 1, "line_text": "        use vstd::hash_map::HashMapWithView;", "energy": -4.387807846069336, "is_buggy": false, "x": 0.48704880475997925, "y": -4.829041481018066}, {"line_idx": 2, "line_text": "        use vstd::prelude::*;", "energy": -3.2416489124298096, "is_buggy": false, "x": 2.7905640602111816, "y": -5.6888628005981445}, {"line_idx": 3, "line_text": "        #[derive(PartialEq, Eq)]", "energy": -4.5405354499816895, "is_buggy": false, "x": -0.4378073215484619, "y": -5.588237285614014}, {"line_idx": 4, "line_text": "        pub struct MyStruct", "energy": -5.2187724113464355, "is_buggy": false, "x": -0.2741960287094116, "y": -1.0617046356201172}, {"line_idx": 5, "line_text": "        {", "energy": -5.337371826171875, "is_buggy": false, "x": -7.774453639984131, "y": 3.2449846267700195}, {"line_idx": 6, "line_text": "            pub i: u16,", "energy": -5.1155829429626465, "is_buggy": false, "x": -0.8187974691390991, "y": -0.9147732257843018}, {"line_idx": 7, "line_text": "            pub j: i32,", "energy": -4.872430324554443, "is_buggy": false, "x": -0.6981953382492065, "y": -0.6983532905578613}, {"line_idx": 8, "line_text"