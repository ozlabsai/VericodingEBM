{"impl": {"impl_id": "verus-real-hash-f58456ef2cd9-pass-test_hash_map_struct-0", "spec_id": "verus-real-hash-f58456ef2cd9", "status": "pass", "whole_impl_energy": -20.414323806762695, "spec_text": "\n        use core::hash::{Hash, Hasher};\n        use std::collections::HashMap;\n        use vstd::prelude::*;\n\n        #[derive(PartialEq, Eq)]\n        struct MyStruct\n        {\n            pub i: u16,\n            pub j: i32,\n        }\n\n        impl Hash for MyStruct\n        {\n            #[verifier::external_body]\n            fn hash<H>(&self, state: &mut H)\n                where\n                    H: Hasher\n            {\n                self.i.hash(state);\n                self.j.hash(state);\n            }\n        }\n\n        fn test()\n        {\n            assume(vstd::std_specs::hash::obeys_key_model::<MyStruct>());\n\n            let mut m = HashMap::<MyStruct, u32>::new();\n            assert(m@ == Map::<MyStruct, u32>::empty());\n            let s1 = MyStruct{ i: 3, j: 7 };\n            m.insert(s1, 4);\n\n            let s2 = MyStruct{ i: 3, j: 7 };\n            assert(m@[s2] == 4);\n            assert(m@.contains_key(s2));\n\n            let b = m.contains_key(&s2);\n            assert(b);\n\n            let v = m.get(&s2);\n            match v {\n                Some(v) => assert(*v == 4),\n                None => assert(false),\n            }\n\n            m.clear();\n            assert(!m@.contains_key(s2));\n            let b = m.contains_key(&s2);\n            assert(!b);\n        }\n    ", "impl_text": "\n        use core::hash::{Hash, Hasher};\n        use std::collections::HashMap;\n        use vstd::prelude::*;\n\n        #[derive(PartialEq, Eq)]\n        struct MyStruct\n        {\n            pub i: u16,\n            pub j: i32,\n        }\n\n        impl Hash for MyStruct\n        {\n            #[verifier::external_body]\n            fn hash<H>(&self, state: &mut H)\n                where\n                    H: Hasher\n    