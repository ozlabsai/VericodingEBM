{"impl": {"impl_id": "verus-real-traits-96f9c1e58cc3-fail-trait_with_const_param_and_assoc_type-127", "spec_id": "verus-real-traits-96f9c1e58cc3", "status": "fail", "whole_impl_energy": -2.5778467655181885, "spec_text": "\n        use vstd::*;\n\n        pub trait Trait<const X: usize> {\n            type AssocType;\n\n            fn exec_get_x(&self) -> (r: usize)\n                ensures r == X;\n\n            fn exec_get_x_2(a: &Self::AssocType) -> (r: usize)\n                ensures r == X;\n        }\n\n        struct Bar<const X: usize> {\n        }\n\n        impl<const X: usize> Trait<X> for Bar<X> {\n            type AssocType = [bool; X];\n\n            fn exec_get_x(&self) -> (r: usize)\n            {\n                return X;\n            }\n\n            fn exec_get_x_2(a: &[bool; X]) -> (r: usize)\n            {\n                return a.len();\n            }\n        }\n", "impl_text": "        fn test_generic<const X: usize, T: Trait<X>>(t: &T, j: &T::AssocType) {\n            let r = t.exec_get_x();\n            assert(r == X);\n\n            let r2 = T::exec_get_x_2(j);\n            assert(r2 == X);\n        }\n\n        fn test_specific<const X: usize>(t: &Bar<X>, j: &<Bar<X> as Trait<X>>::AssocType) {\n            let r = t.exec_get_x();\n            assert(r == X);\n\n            let r2 = <Bar<X> as Trait<X>>::exec_get_x_2(j);\n            assert(r2 == X);\n        }\n\n        fn test_generic_fail<const X: usize, T: Trait<X>>(t: &T, j: &T::AssocType) {\n            let r = t.exec_get_x();\n            assert(r == X);\n\n            let r2 = T::exec_get_x_2(j);\n            assert(r2 == X);\n\n            assert(false); // FAILS\n        }\n\n        fn test_specific_fail<const X: usize>(t: &Bar<X>, j: &<Bar<X> as Trait<X>>::AssocType) {\n            let r = t.exec_get_x();\n            assert(r == X);\n\n            let r2 = <Bar<X> as Trait<X>>::exec_get_x_2(j);\n            assert(r2 == X);\n\n            assert(false); // FAILS\n        }\n