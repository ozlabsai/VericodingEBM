# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
build/
# `dist/` is Python's wheel-output convention; ignore globally EXCEPT the
# frontend's vite build output (shipped as the static demo).
dist/
!demo/frontend/dist/
wheels/
.pytest_cache/
.ruff_cache/

# IDE
.vscode/
.idea/
*.swp

# Env / secrets
.env
.env.*
!.env.example

# Internal docs (handoffs, plans, agent notes)
.internal/

# Data / weights / training state (heavy, regenerable)
/data/
checkpoints/
wandb/
runs/
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.parquet
docs/RESEARCH_NOTEBOOK.md

# Artifacts: ignore by default, then un-ignore the released eval/baseline
# records that the paper analyses depend on. Heavyweight outputs (logs,
# binary dumps, intermediate scratch) stay ignored.
artifacts/*
